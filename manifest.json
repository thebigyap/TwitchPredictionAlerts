{
  "manifest_version": 3,
  "name": "Twitch Prediction Alerts",
  "description": "Detects Twitch prediction events and plays an alert sound.",
  "version": "1.1.0",
  "permissions": ["storage"],
  "action": {
    "default_title": "Twitch Prediction Alerts",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.twitch.tv/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sounds/alert.mp3",
        "sounds/countdown.mp3"
      ],
      "matches": [
        "https://www.twitch.tv/*"
      ]
    }
  ]
}
